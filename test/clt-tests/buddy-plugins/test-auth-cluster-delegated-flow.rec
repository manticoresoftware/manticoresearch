––– comment –––
Test delegated cluster flow with non-replication session user in 2-node replication setup.

Scenario:
1) Session user `norepluser` has read/write/schema but no replication.
2) Cluster/effective replication user is `repluser` (has replication).
3) Whole flow is executed from `norepluser`:
   CREATE CLUSTER -> JOIN CLUSTER -> ALTER CLUSTER ADD -> INSERT -> SELECT on node2 -> DELETE CLUSTER.
––– comment –––
––– input –––
export INSTANCE=1
––– output –––
––– block: ../base/replication/start-searchd-precach-with-auth –––
––– input –––
export INSTANCE=2
––– output –––
––– block: ../base/replication/start-searchd-precach-with-auth –––
––– comment –––
––– Setup users on both nodes –––
––– comment –––
––– input –––
for port in 1306 2306; do MYSQL_PWD=adminpass mysql -uadmin -h0 -P$port -e "CREATE USER 'repluser' IDENTIFIED BY 'repluser1234';" >/dev/null; MYSQL_PWD=adminpass mysql -uadmin -h0 -P$port -e "GRANT replication ON * TO 'repluser';" >/dev/null; MYSQL_PWD=adminpass mysql -uadmin -h0 -P$port -e "CREATE USER 'norepluser' IDENTIFIED BY 'noreplpass1';" >/dev/null; MYSQL_PWD=adminpass mysql -uadmin -h0 -P$port -e "GRANT read ON * TO 'norepluser';" >/dev/null; MYSQL_PWD=adminpass mysql -uadmin -h0 -P$port -e "GRANT write ON * TO 'norepluser';" >/dev/null; MYSQL_PWD=adminpass mysql -uadmin -h0 -P$port -e "GRANT schema ON * TO 'norepluser';" >/dev/null; done; echo "Users ready"
––– output –––
Users ready
––– comment –––
––– Negative check: norepluser cannot be used as effective replication user –––
––– comment –––
––– input –––
MYSQL_PWD=noreplpass1 mysql -unorepluser -h0 -P1306 -e "CREATE CLUSTER badcluster 'norepluser' AS user;" 2>&1
––– output –––
ERROR 1064 (42000) at line 1: Permission denied for user 'norepluser'
––– comment –––
––– Node1: create cluster as norepluser, delegate replication to repluser –––
––– comment –––
––– input –––
MYSQL_PWD=noreplpass1 mysql -unorepluser -h0 -P1306 -e "CREATE CLUSTER mycluster 'repluser' AS user;" >/dev/null; echo $?
––– output –––
0
––– comment –––
––– Node2: join cluster as norepluser, delegate replication to repluser –––
––– comment –––
––– input –––
MYSQL_PWD=noreplpass1 mysql -unorepluser -h0 -P2306 -e "JOIN CLUSTER mycluster AT '127.0.0.1:1312' 'repluser' AS user;" >/dev/null; echo $?
––– output –––
0
––– input –––
bash -c 'end=$((SECONDS+120)); while [ $SECONDS -lt $end ]; do ok=true; for port in 1306 2306; do mysql -h0 -P$port -e "SHOW STATUS LIKE '\''cluster_mycluster_status'\''\G" > /tmp/status_$port.log 2>/dev/null && grep -q "Value: primary" /tmp/status_$port.log || { ok=false; break; }; done; if $ok; then echo "Port 1306: Node synced"; echo "Port 2306: Node synced"; exit 0; fi; sleep 1; done; echo "Timeout waiting for nodes to sync!"; exit 1'
––– output –––
Port 1306: Node synced
Port 2306: Node synced
––– comment –––
––– Node1 regular flow as norepluser –––
––– comment –––
––– input –––
MYSQL_PWD=noreplpass1 mysql -unorepluser -h0 -P1306 -e "CREATE TABLE t1 (id BIGINT, title TEXT);" >/dev/null; echo $?
––– output –––
0
––– input –––
MYSQL_PWD=noreplpass1 mysql -unorepluser -h0 -P1306 -e "ALTER CLUSTER mycluster ADD t1;" >/dev/null; echo $?
––– output –––
0
––– input –––
MYSQL_PWD=noreplpass1 mysql -unorepluser -h0 -P1306 -e "INSERT INTO mycluster:t1 VALUES (1,'delegated replication works');" >/dev/null; echo $?
––– output –––
0
––– comment –––
––– Node2 must see replicated row from node1 –––
––– comment –––
––– input –––
timeout 30 bash -c 'while true; do c=$(MYSQL_PWD=noreplpass1 mysql -sN -unorepluser -h0 -P2306 -e "SELECT COUNT(*) FROM mycluster:t1 WHERE id=1;" 2>/dev/null); [ "$c" = "1" ] && exit 0; sleep 1; done'; echo $?
––– output –––
0
––– input –––
MYSQL_PWD=noreplpass1 mysql -sN -unorepluser -h0 -P2306 -e "SELECT id,title FROM mycluster:t1 ORDER BY id ASC;"
––– output –––
#!/1[[:space:]]+delegated replication works/!#
––– comment –––
––– Node1: delete cluster as norepluser (uses cluster user for replication auth) –––
––– comment –––
––– input –––
MYSQL_PWD=noreplpass1 mysql -unorepluser -h0 -P1306 -e "DELETE CLUSTER mycluster;" >/dev/null; echo $?
––– output –––
0
