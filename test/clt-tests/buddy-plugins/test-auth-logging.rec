––– comment –––
Test auth logging: all auth changes should be recorded.
Spec: https://github.com/manticoresoftware/manticoresearch/blob/wip_auth/src/auth/spec.md
Issue: https://github.com/manticoresoftware/manticoresearch/issues/2983
Admin credentials: admin / adminpass (bootstrap via auth.json)

Per spec: Auth-related operations should be logged
––– comment –––
––– block: ../base/start-searchd-with-auth –––
––– comment –––
––– 7.1.1 CREATE USER is logged –––
EXPECTED: CREATE USER operation appears in log
––– comment –––
––– input –––
MYSQL_PWD=adminpass mysql -E -uadmin -h0 -P9306 -e "CREATE USER 'loguser' IDENTIFIED BY 'loguser12345';"
––– output –––
*************************** 1. row ***************************
       token: #!/[0-9a-f]{64}/!#
    username: loguser
generated_at: #!/([0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}|[A-Z][a-z]{2} [A-Z][a-z]{2} [ 0-9][0-9] [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3} [0-9]{4})/!#
––– input –––
sleep 1; grep -c "loguser" /var/log/manticore/searchd.log.auth
––– output –––
#!/[1-9][0-9]*/!#
––– comment –––
––– 7.1.2 DROP USER is logged –––
EXPECTED: DROP USER operation appears in log
––– comment –––
––– input –––
MYSQL_PWD=adminpass mysql -E -uadmin -h0 -P9306 -e "CREATE USER 'droplog_user' IDENTIFIED BY 'droplogpass123';"
––– output –––
*************************** 1. row ***************************
       token: #!/[0-9a-f]{64}/!#
    username: droplog_user
generated_at: #!/([0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}|[A-Z][a-z]{2} [A-Z][a-z]{2} [ 0-9][0-9] [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3} [0-9]{4})/!#
––– input –––
sleep 1; grep -Ec "user 'droplog_user' deleted by 'admin' via" /var/log/manticore/searchd.log.auth
––– output –––
0
––– input –––
MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e "DROP USER 'droplog_user';"
––– output –––
––– input –––
sleep 1; grep -Ec "user 'droplog_user' deleted by 'admin' via" /var/log/manticore/searchd.log.auth
––– output –––
#!/[1-9][0-9]*/!#
––– comment –––
––– 7.1.3 GRANT is logged –––
EXPECTED: GRANT operation appears in log
––– comment –––
––– input –––
MYSQL_PWD=adminpass mysql -E -uadmin -h0 -P9306 -e "CREATE USER 'grantlog' IDENTIFIED BY 'grantlog123';"
––– output –––
*************************** 1. row ***************************
       token: #!/[0-9a-f]{64}/!#
    username: grantlog
generated_at: #!/([0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}|[A-Z][a-z]{2} [A-Z][a-z]{2} [ 0-9][0-9] [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3} [0-9]{4})/!#
––– input –––
MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e "GRANT read ON * TO 'grantlog';"
––– output –––
––– input –––
sleep 1; grep -Ec "granted read on '\\*' to user 'grantlog' by 'admin' via" /var/log/manticore/searchd.log.auth
––– output –––
#!/[1-9][0-9]*/!#
––– input –––
MYSQL_PWD=adminpass mysql -E -uadmin -h0 -P9306 -e "DROP USER 'grantlog';"
––– output –––
––– comment –––
––– 7.1.4 Failed authentication is logged –––
EXPECTED: Failed login attempts appear in log
––– comment –––
––– input –––
MYSQL_PWD=wrongpass mysql -ufakeuser -h0 -P9306 -e "SELECT 1;" 2>&1
––– output –––
ERROR 1045 (42000): Access denied for user 'fakeuser' (using password: YES)
––– input –––
timeout 5 bash -c 'until [ "$(grep -ic "fakeuser" /var/log/manticore/searchd.log.auth)" -ge 1 ]; do sleep 0.2; done'; grep -ic "fakeuser" /var/log/manticore/searchd.log.auth
––– output –––
#!/[1-9][0-9]*/!#
––– input –––
timeout 5 bash -c 'until grep -Fq "via SphinxQL" /var/log/manticore/searchd.log.auth; do sleep 0.2; done'; if grep -Fq "SphixnQL" /var/log/manticore/searchd.log.auth; then echo "SphixnQL present"; else echo "SphixnQL absent"; fi
––– output –––
SphixnQL absent
––– comment –––
––– 7.1.5 Failed Bearer auth redacts attempted token –––
EXPECTED: Failed Bearer auth is logged with a fingerprint, not the raw token
––– comment –––
––– input –––
BAD_BEARER=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef; curl -s -H "Authorization: Bearer $BAD_BEARER" http://127.0.0.1:9308/sql -d "query=SELECT 1" >/dev/null; timeout 5 bash -c 'until grep -Eq "failed authentication attempt for bearer fingerprint sha256=[0-9a-f]{12} length=64 via HTTP Bearer" /var/log/manticore/searchd.log.auth; do sleep 0.2; done'; if grep -Fq "$BAD_BEARER" /var/log/manticore/searchd.log.auth; then echo "raw token leaked"; else echo "raw token absent"; fi; grep -Eo "fingerprint sha256=[0-9a-f]{12} length=64" /var/log/manticore/searchd.log.auth | tail -1
––– output –––
raw token absent
#!/fingerprint sha256=[0-9a-f]{12} length=64/!#
––– comment –––
––– 7.1.6 safe MySQL metadata probe does not log targetless denial –––
EXPECTED: write-only user can run safe compatibility sysvar probe, but arbitrary targetless SELECT still requires read
––– comment –––
––– input –––
MYSQL_PWD=adminpass mysql -E -uadmin -h0 -P9306 -e "CREATE USER 'compatwriter' IDENTIFIED BY 'compatwriter123';"
––– output –––
*************************** 1. row ***************************
       token: #!/[0-9a-f]{64}/!#
    username: compatwriter
generated_at: #!/([0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}|[A-Z][a-z]{2} [A-Z][a-z]{2} [ 0-9][0-9] [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3} [0-9]{4})/!#
––– input –––
MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e "GRANT write ON * TO 'compatwriter';"
––– output –––
––– input –––
truncate -s 0 /var/log/manticore/searchd.log.auth; MYSQL_PWD=compatwriter123 mysql -ucompatwriter -h0 -P9306 -e "SELECT @@version_comment;" >/dev/null && echo "compat metadata query ok"; if grep -Fq "compatwriter" /var/log/manticore/searchd.log.auth; then cat /var/log/manticore/searchd.log.auth; else echo "compat metadata denial absent"; fi
––– output –––
compat metadata query ok
compat metadata denial absent
––– input –––
MYSQL_PWD=compatwriter123 mysql -ucompatwriter -h0 -P9306 -e "SELECT 1;" 2>&1
––– output –––
ERROR 1045 (42000) at line 1: Permission denied for user 'compatwriter'
––– comment –––
––– 7.1.7 all logs user-facing success without internal Buddy success –––
EXPECTED: auth_log_level=all logs real user success and skips successful system.buddy auth
––– comment –––
––– input –––
searchd --stopwait >/dev/null 2>&1 || true; sed -i '/^[[:space:]]*auth_log_level[[:space:]]*=/d' /etc/manticoresearch/manticore.conf; sed -i '/^searchd/a\    auth_log_level = all' /etc/manticoresearch/manticore.conf; rm -f /var/log/manticore/searchd.log /var/log/manticore/searchd.log.auth; stdbuf -oL searchd $SEARCHD_FLAGS > /dev/null; if timeout 10 grep -qm1 '\[BUDDY\] started' <(tail -n 1000 -f /var/log/manticore/searchd.log); then echo 'Buddy started!'; else echo 'Timeout or failed!'; cat /var/log/manticore/searchd.log; fi; MYSQL_PWD=adminpass mysql -N -B -uadmin -h0 -P9306 -e "SELECT 1" >/dev/null; if timeout 5 bash -c "until grep -Eq \"\\[ALL\\] user 'admin' successfully authenticated via SphinxQL\" /var/log/manticore/searchd.log.auth 2>/dev/null; do sleep 0.2; done"; then echo "admin all success logged"; else cat /var/log/manticore/searchd.log.auth; fi; sleep 1; if grep -Fq "user 'system.buddy' successfully authenticated" /var/log/manticore/searchd.log.auth; then echo "buddy success present at all"; else echo "buddy success absent at all"; fi
––– output –––
Buddy started!
admin all success logged
buddy success absent at all
––– comment –––
––– 7.1.8 trace logs internal Buddy success –––
EXPECTED: auth_log_level=trace includes successful system.buddy auth
––– comment –––
––– input –––
searchd --stopwait >/dev/null 2>&1 || true; sed -i '/^[[:space:]]*auth_log_level[[:space:]]*=/d' /etc/manticoresearch/manticore.conf; sed -i '/^searchd/a\    auth_log_level = trace' /etc/manticoresearch/manticore.conf; rm -f /var/log/manticore/searchd.log /var/log/manticore/searchd.log.auth; stdbuf -oL searchd $SEARCHD_FLAGS > /dev/null; if timeout 10 grep -qm1 '\[BUDDY\] started' <(tail -n 1000 -f /var/log/manticore/searchd.log); then echo 'Buddy started!'; else echo 'Timeout or failed!'; cat /var/log/manticore/searchd.log; fi; if timeout 10 bash -c "until grep -Eq \"\\[TRACE\\] user 'system.buddy' successfully authenticated via HTTP Bearer\" /var/log/manticore/searchd.log.auth 2>/dev/null; do sleep 0.2; done"; then echo "buddy trace success logged"; else cat /var/log/manticore/searchd.log.auth; fi
––– output –––
Buddy started!
buddy trace success logged
