––– comment –––
Test multi-statement SQL permission enforcement.
Admin credentials: admin / adminpass (bootstrap via auth.json)

Per request, every parsed statement must pass authorization before any multi-result
response is sent. A permitted first statement must not authorize later SELECTs that
target an ungranted table or internal auth storage.
––– comment –––
––– block: ../base/start-searchd-with-auth –––
––– comment –––
––– Setup: create a public table, a private table, and one scoped reader –––
––– comment –––
––– input –––
MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e "CREATE TABLE public_idx(content text, tag integer);"
––– output –––
––– input –––
MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e "CREATE TABLE private_idx(secret text, tag integer);"
––– output –––
––– input –––
MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e "INSERT INTO public_idx(id, content, tag) VALUES(1, 'public row', 10);"
––– output –––
––– input –––
MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e "INSERT INTO private_idx(id, secret, tag) VALUES(1, 'private row', 20);"
––– output –––
––– input –––
MYSQL_PWD=adminpass mysql -E -uadmin -h0 -P9306 -e "CREATE USER 'scoped' IDENTIFIED BY 'scopedpass1';"
––– output –––
*************************** 1. row ***************************
       token: #!/[0-9a-f]{64}/!#
    username: scoped
generated_at: #!/([0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}|[A-Z][a-z]{2} [A-Z][a-z]{2} [ 0-9][0-9] [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3} [0-9]{4})/!#
––– input –––
MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e "GRANT read ON public_idx TO 'scoped';"
––– output –––
––– comment –––
––– 6.2.1 Direct permitted SELECT works –––
EXPECTED: scoped can read public_idx.
––– comment –––
––– input –––
MYSQL_PWD=scopedpass1 mysql -E -uscoped -h0 -P9306 -e "SELECT id, content, tag FROM public_idx;"
––– output –––
*************************** 1. row ***************************
     id: 1
content: public row
    tag: 10
––– comment –––
––– 6.2.2 Direct ungranted SELECT is denied –––
EXPECTED: scoped cannot read private_idx.
––– comment –––
––– input –––
MYSQL_PWD=scopedpass1 mysql -uscoped -h0 -P9306 -e "SELECT id, secret, tag FROM private_idx;" 2>&1
––– output –––
ERROR 1045 (42000) at line 1: Permission denied for user 'scoped'
––– comment –––
––– 6.2.3 Multi-statement with only permitted targets works –––
EXPECTED: mysqli multi_query() can execute two authorized statements.
––– comment –––
––– input –––
php -r 'mysqli_report(MYSQLI_REPORT_OFF); $m = new mysqli("127.0.0.1", "scoped", "scopedpass1", "", 9306); if (!$m->multi_query("SELECT id FROM public_idx; SELECT tag FROM public_idx")) { echo "public_public: ERR ".$m->errno."\n"; exit; } echo "public_public: RESULT\n"; while ($m->more_results() && $m->next_result()) {}'
––– output –––
public_public: RESULT
––– comment –––
––– 6.2.4 Permitted first SELECT does not authorize ungranted tail SELECT –––
EXPECTED: the request is denied before returning a partial first result.
––– comment –––
––– input –––
php -r 'mysqli_report(MYSQLI_REPORT_OFF); foreach (["public_private"=>"SELECT id, content, tag FROM public_idx; SELECT id, secret, tag FROM private_idx", "public_auth_users"=>"SELECT id, content, tag FROM public_idx; SELECT username, hashes FROM system.auth_users", "public_auth_permissions"=>"SELECT id, content, tag FROM public_idx; SELECT username, action, target FROM system.auth_permissions"] as $label=>$sql) { $m = new mysqli("127.0.0.1", "scoped", "scopedpass1", "", 9306); echo $label.": ".($m->multi_query($sql) ? "RESULT" : "ERR ".$m->errno)."\n"; }'
––– output –––
public_private: ERR 1045
public_auth_users: ERR 1045
public_auth_permissions: ERR 1045
––– comment –––
––– 6.2.5 One SELECT over multiple regular tables still checks every target –––
EXPECTED: scoped cannot read a multi-index SELECT that includes private_idx.
––– comment –––
––– input –––
MYSQL_PWD=scopedpass1 mysql -uscoped -h0 -P9306 -e "SELECT * FROM public_idx,private_idx;" 2>&1
––– output –––
ERROR 1045 (42000) at line 1: Permission denied for user 'scoped'
––– comment –––
––– 6.2.6 One SELECT cannot dump an auth table alongside a normal table –––
EXPECTED: the request must fail, either as a syntax error for dotted auth storage
or as an auth denial if that syntax becomes parseable later.
––– comment –––
––– input –––
MYSQL_PWD=scopedpass1 mysql -uscoped -h0 -P9306 -e "SELECT * FROM public_idx,system.auth_users;" 2>&1 | awk '/^ERROR/ {print}'
––– output –––
#!/ERROR (1045|1064).*/!#
––– comment –––
––– 6.2.7 HTTP raw SQL uses the same per-statement authorization –––
EXPECTED: /sql?mode=raw returns 403 instead of leaking the second result set.
––– comment –––
––– input –––
curl -s -i -u scoped:scopedpass1 -X POST "http://127.0.0.1:9308/sql?mode=raw" -d "SELECT id, content, tag FROM public_idx; SELECT username, hashes FROM system.auth_users" | tr -d '\r' | awk '/^HTTP\/1.1|^\{"error":/ {print}'
––– output –––
HTTP/1.1 403 Forbidden
{"error":"Permission denied for user 'scoped'"}
