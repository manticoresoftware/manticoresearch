––– comment –––
Ask CLARIFICATION question, so query and results should be the same
––– input –––
mysql -h0 -P9306 -e "CALL CONVERSATIONAL_RAG('When this language was created?', 'docs', 'test_assistant', 'content', 'test-conv-intent-001')\G;" | tee /tmp/output_8.txt
––– output –––
*************************** 1. row ***************************
conversation_uuid: test-conv-intent-001
       user_query: When this language was created?
     search_query: #!/.*[Pp]ython.*/!#
         response: #!/.*[Pp]ython.*/!#
          sources: #!/\[.*/!#
––– input –––
Q7=$(grep -o 'search_query: .*' /tmp/output_7.txt | sed 's/search_query: //'); S7=$(grep -o '\[.*\]' /tmp/output_7.txt | head -1); Q8=$(grep -o 'search_query: .*' /tmp/output_8.txt | sed 's/search_query: //'); S8=$(grep -o '\[.*\]' /tmp/output_8.txt | head -1); if [ "$Q7" = "$Q8" ] && [ "$S7" = "$S8" ]; then echo "OK - Context memory works"; else echo "FAIL - Context memory broken"; echo "Q7: $Q7"; echo "Q8: $Q8"; echo "Sources7: $(echo "$S7" | jq 'length') items"; echo "Sources8: $(echo "$S8" | jq 'length') items"; fi
––– output –––
OK
––– comment –––
