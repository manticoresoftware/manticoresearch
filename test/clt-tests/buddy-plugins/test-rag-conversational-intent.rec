mysql -h0 -P9306 -e "CALL CONVERSATIONAL_RAG('Tell me about TV shows', 'docs', 'test_assistant', 'content,title', 'conv-expand-001')\G" | tee /tmp/rag_b1.txt | grep -E "conversation_uuid:|response:|sources:"
