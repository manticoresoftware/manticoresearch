––– comment –––
Join preservation: fallback must undo only JSON SI rewrites and keep join-side filter removal.
––– input –––
mysql -h0 -P9306 -e "DROP TABLE IF EXISTS gh4345_join_left; DROP TABLE IF EXISTS gh4345_join_right; CREATE TABLE gh4345_join_left (id BIGINT, properties JSON secondary_index='1'); CREATE TABLE gh4345_join_right (id BIGINT, left_id BIGINT, marker INT); INSERT INTO gh4345_join_left VALUES (1, '{\"channels\":[29]}'), (2, '{\"channels\":[30]}'); INSERT INTO gh4345_join_right VALUES (10, 1, 7), (11, 1, 8), (12, 2, 7); FLUSH RAMCHUNK gh4345_join_left; FLUSH RAMCHUNK gh4345_join_right;"
––– output –––
––– input –––
mysql -h0 -P9306 -e "SET GLOBAL secondary_indexes=0; SELECT gh4345_join_left.id AS left_id, gh4345_join_right.marker AS marker, IN (properties.channels, 29) AS p2 FROM gh4345_join_left INNER JOIN gh4345_join_right ON gh4345_join_right.left_id = gh4345_join_left.id WHERE p2=1 AND gh4345_join_right.marker=7 ORDER BY left_id ASC;"
––– output –––
+---------+--------+------+
| left_id | marker | p2   |
+---------+--------+------+
|       1 |      7 |    1 |
+---------+--------+------+
