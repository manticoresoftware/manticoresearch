––– comment –––
Regression coverage for issue #4345:
JSON secondary-index filter rewrites must not leak into no-iterator fallback paths.
This file keeps the original filter-tree repro, plus fallback/control variants that share one daemon startup.
––– block: ../base/start-searchd –––
––– comment –––
Original repro: filter tree on a disk chunk should still evaluate the JSON expression alias after fallback.
––– input –––
mysql -h0 -P9306 -e "SET GLOBAL auto_optimize=0; DROP TABLE IF EXISTS gh4345_mini; CREATE TABLE gh4345_mini (id BIGINT, properties JSON secondary_index='1'); INSERT INTO gh4345_mini VALUES (1, '{\"loginName\":\"alpha\",\"subscriptions\":[{\"nextRenewal\":177300000}],\"channels\":[29]}'), (2, '{\"loginName\":\"alpha\",\"subscriptions\":[],\"channels\":[30]}'); FLUSH RAMCHUNK gh4345_mini;"
––– output –––
––– input –––
mysql -h0 -P9306 -e "SHOW TABLE gh4345_mini STATUS LIKE 'disk_chunks';"
––– output –––
+---------------+-------+
| Variable_name | Value |
+---------------+-------+
| disk_chunks   | 1     |
+---------------+-------+
––– input –––
mysql -h0 -P9306 -e "SELECT id, ANY ( s.nextRenewal > 177274800 FOR s IN properties.subscriptions) AS p0, REGEX (properties.loginName, '(?i)visitor') AS p1, IN (properties.channels, 29) AS p2 FROM gh4345_mini;"
––– output –––
+------+------+------+------+
| id   | p0   | p1   | p2   |
+------+------+------+------+
|    1 |    1 |    0 |    1 |
|    2 |    0 |    0 |    0 |
+------+------+------+------+
––– input –––
mysql -h0 -P9306 -e "SELECT id, properties.loginName, ANY ( s.nextRenewal > 177274800 FOR s IN properties.subscriptions) AS p0, REGEX (properties.loginName, '(?i)visitor') AS p1, IN (properties.channels, 29) AS p2 FROM gh4345_mini WHERE (p1 = 1 OR p0 = 1) LIMIT 0,5; SHOW META;"
