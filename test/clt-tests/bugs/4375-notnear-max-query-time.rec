––– input –––
manticore-load --quiet --json --batch-size=1000 --threads=8 --total=100000 --init="CREATE TABLE test3(id bigint, doc text, type int)" --load="INSERT INTO test3(id,doc,type) VALUES(<increment>,'<text/{/tmp/issue-4375-words.txt}/10/100>',<int/1/100>)"
