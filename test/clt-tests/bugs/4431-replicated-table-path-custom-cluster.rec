export INSTANCE=2; stdbuf -oL searchd -c test/clt-tests/base/searchd-with-flexible-ports.conf > /tmp/rt_4431_path_restart.out 2>&1; if timeout 10 grep -qm1 '\[BUDDY\] started' <(tail -n 1000 -f /var/log/manticore-${INSTANCE}/searchd.log); then echo 'Buddy started!'; else echo 'Timeout or failed!'; cat /tmp/rt_4431_path_restart.out; cat /var/log/manticore-${INSTANCE}/searchd.log; fi
