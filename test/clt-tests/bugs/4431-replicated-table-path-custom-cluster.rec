bash -c '[ -f /var/log/manticore-2/rt_4431_path/rt_4431_path.lock ] && echo "ROOT_LOCK=yes" || echo "ROOT_LOCK=no"; [ -f /var/log/manticore-2/c_node2/rt_4431_path/rt_4431_path.lock ] && echo "CLUSTER_LOCK=yes" || echo "CLUSTER_LOCK=no"; awk '\''/"indexes":\{/{inidx=1} inidx && /"rt_4431_path"/{hit=1} hit && /"path"/{gsub(/[ \t,]/,""); print; exit}'\'' /var/log/manticore-2/manticore.json'
