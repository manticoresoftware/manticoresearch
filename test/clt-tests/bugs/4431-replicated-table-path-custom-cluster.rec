mysql -h0 -P1306 -e "CREATE CLUSTER c4431 'c_node1' AS path;" && mysql -h0 -P2306 -e "JOIN CLUSTER c4431 AT '127.0.0.1:1312' 'c_node2' AS path;"
––– output –––
––– input –––
bash -c 'end=$((SECONDS+90)); while [ $SECONDS -lt $end ]; do mysql -h0 -P2306 -N -B -e "SHOW STATUS LIKE '\''cluster_c4431_node_state'\''" 2>/dev/null | grep -qw synced && { echo "NODE2_SYNCED=yes"; exit 0; }; sleep 1; done; echo "NODE2_SYNCED=no"; exit 0'
––– output –––
NODE2_SYNCED=yes
––– input –––
mysql -h0 -P1306 -e "CREATE TABLE rt_4431_path (id bigint, title text);" && mysql -h0 -P1306 -e "ALTER CLUSTER c4431 ADD rt_4431_path;" && mysql -h0 -P1306 -e "INSERT INTO c4431:rt_4431_path VALUES (1,'before restart');" && sleep 2
––– output –––
––– input –––
mysql -h0 -P2306 -e "SELECT COUNT(*) AS cnt FROM rt_4431_path;" | grep -E '^[|][[:space:]]+1[[:space:]]+[|]$' >/dev/null && echo "NODE2_TABLE_BEFORE_RESTART=ok" || echo "NODE2_TABLE_BEFORE_RESTART=failed"
––– output –––
NODE2_TABLE_BEFORE_RESTART=ok
