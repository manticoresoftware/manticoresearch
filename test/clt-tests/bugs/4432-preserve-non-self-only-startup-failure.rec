––– output –––
––– input –––
bash <<'EOF'
seqno() { mysql -E -h0 -P"$1" -e "SHOW STATUS LIKE 'cluster_${2}_state_seqno';" 2>/tmp/c4432_preserve_seqno.err | awk '/Value:/{print $2; exit}'; }
wait_seq() { mysql -E -h0 -P"$1" -e "debug wait $2 status $3 like 'state' option 'timeout'=30;" 2>&1; }
wait_ready() {
	port="$1"
	cluster="$2"
	deadline=$((SECONDS+90))
	while [ $SECONDS -lt $deadline ]; do
		wait_out=$(mysql -E -h0 -P"$port" -e "debug wait $cluster like 'state' option 'timeout'=5;" 2>&1 || true)
		status_out=$(mysql -E -h0 -P"$port" -e "SHOW STATUS LIKE 'cluster_${cluster}_%';" 2>&1 || true)
		{
			echo "$wait_out"
			echo "$status_out"
		} >"/tmp/c4432_preserve_ready_$port.out"
		echo "$wait_out" | grep -q "Value: synced" &&
			echo "$status_out" | grep -q "Counter: cluster_${cluster}_nodes_set" &&
			echo "$status_out" | grep -q "127.0.0.1:1312" &&
			echo "$status_out" | grep -q "127.0.0.1:2312" &&
			echo "$status_out" | grep -q "Counter: cluster_${cluster}_node_state" &&
			echo "$status_out" | grep -q "Value: synced" &&
			return 0
	done
	return 1
}
wait_ok() { echo "$1" | awk -v want="$2" '/Value:/{ if ($2>=want) ok=1 } END{ exit ok ? 0 : 1 }'; }
has_index() { mysql -N -B -h0 -P"$1" -e "SHOW STATUS LIKE 'cluster_${2}_indexes';" 2>/tmp/c4432_preserve_indexes_$1.err | grep -qw "$3"; }
has_row() { mysql -N -B -h0 -P"$1" -e "SELECT COUNT(*) FROM $2;" 2>/tmp/c4432_preserve_count_$1.err | awk '{ if ($1>0) ok=1 } END{ exit ok ? 0 : 1 }'; }

mysql -h0 -P1306 -e "CREATE TABLE t4432_preserve (id bigint, title text);" >/tmp/c4432_preserve_setup.out 2>&1
if ! wait_ready 2306 c4432_preserve; then
	echo "NEG_SETUP=not_ready"
	cat /tmp/c4432_preserve_join.out /tmp/c4432_preserve_ready_*.out 2>/dev/null || true
	exit 0
fi

before_add=$(seqno 2306 c4432_preserve)
[ -n "$before_add" ] || before_add=0
want_add=$((before_add+1))
mysql -h0 -P1306 -e "ALTER CLUSTER c4432_preserve ADD t4432_preserve;" >>/tmp/c4432_preserve_setup.out 2>&1
wait_add=$(wait_seq 2306 c4432_preserve "$want_add")
if ! wait_ok "$wait_add" "$want_add" && ! has_index 2306 c4432_preserve t4432_preserve; then
	echo "NEG_SETUP=add_failed"
	echo "$wait_add"
	cat /tmp/c4432_preserve_setup.out /tmp/c4432_preserve_ready_*.out 2>/dev/null || true
	exit 0
fi

before_insert=$(seqno 2306 c4432_preserve)
[ -n "$before_insert" ] || before_insert=0
want_insert=$((before_insert+1))
mysql -h0 -P1306 -e "INSERT INTO c4432_preserve:t4432_preserve VALUES (1,'before peer stop');" >>/tmp/c4432_preserve_setup.out 2>&1
wait_insert=$(wait_seq 2306 c4432_preserve "$want_insert")
if wait_ok "$wait_insert" "$want_insert" || has_row 2306 t4432_preserve; then
	echo "NEG_SETUP=ok"
	exit 0
fi

echo "NEG_SETUP=insert_failed"
echo "$wait_insert"
cat /tmp/c4432_preserve_setup.out /tmp/c4432_preserve_ready_*.out 2>/dev/null || true
mysql -h0 -P1306 -E -e "SHOW STATUS LIKE 'cluster_c4432_preserve_%'" 2>&1 || true
mysql -h0 -P2306 -E -e "SHOW STATUS LIKE 'cluster_c4432_preserve_%'" 2>&1 || true
EOF
