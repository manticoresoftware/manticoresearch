AUTO_RECOVERY_PRIMARY_SYNCED=yes
––– input –––
bash <<'EOF'
set -e
mysql -h0 -P1306 -e "INSERT INTO c4432_auto:t4432_auto VALUES (2,'after restart');" >/tmp/c4432_auto_insert.out 2>&1
count=$(mysql -h0 -P1306 -E -e "SELECT COUNT(*) AS total FROM t4432_auto;" 2>/tmp/c4432_auto_count.out | tr -d "\r")
if echo "$count" | grep -q "total: 2"; then
	echo "AUTO_CLUSTER_INSERT=ok"
	exit 0
fi
echo "AUTO_CLUSTER_INSERT=failed"
cat /tmp/c4432_auto_insert.out /tmp/c4432_auto_count.out 2>/dev/null || true
mysql -h0 -P1306 -E -e "SHOW STATUS LIKE 'cluster_c4432_auto_%'" 2>&1 || true
EOF
