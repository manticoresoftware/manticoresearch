seqno() { mysql -E -h0 -P"$1" -e "SHOW STATUS LIKE 'cluster_${2}_state_seqno';" 2>/tmp/c4432_auto_seqno.err | awk '/Value:/{print $2; exit}'; }
wait_seq() { mysql -E -h0 -P"$1" -e "debug wait $2 status $3 like 'state' option 'timeout'=30;" 2>&1; }
wait_ok() { echo "$1" | awk -v want="$2" '/Value:/{ if ($2>=want) ok=1 } END{ exit ok ? 0 : 1 }'; }

mysql -h0 -P1306 -e "CREATE TABLE t4432_auto (id bigint, title text);" >/tmp/c4432_auto_create.out 2>&1
before_add=$(seqno 2306 c4432_auto)
want_add=$((before_add+1))
mysql -h0 -P1306 -e "ALTER CLUSTER c4432_auto ADD t4432_auto;" >/tmp/c4432_auto_alter.out 2>&1
wait_add=$(wait_seq 2306 c4432_auto "$want_add")
after_add=$(seqno 2306 c4432_auto)

if wait_ok "$wait_add" "$want_add"; then
	before_insert=$(seqno 2306 c4432_auto)
	want_insert=$((before_insert+1))
	mysql -h0 -P1306 -e "INSERT INTO c4432_auto:t4432_auto VALUES (1,'before exit');" >/tmp/c4432_auto_insert_setup.out 2>&1
	wait_insert=$(wait_seq 2306 c4432_auto "$want_insert")
	after_insert=$(seqno 2306 c4432_auto)
	if wait_ok "$wait_insert" "$want_insert" && mysql -h0 -P2306 -e "EXIT CLUSTER c4432_auto;" >/tmp/c4432_auto_exit.out 2>&1; then
		echo "AUTO_TABLE_ADDED=yes"
		exit 0
	fi
fi

echo "AUTO_TABLE_ADDED=no"
echo "AUTO_ADD_BEFORE=$before_add AUTO_ADD_WANTED=$want_add AUTO_ADD_AFTER=$after_add"
echo "AUTO_INSERT_BEFORE=$before_insert AUTO_INSERT_WANTED=$want_insert AUTO_INSERT_AFTER=$after_insert"
cat /tmp/c4432_auto_create.out /tmp/c4432_auto_alter.out /tmp/c4432_auto_insert_setup.out /tmp/c4432_auto_exit.out 2>/dev/null || true
echo "$wait_add"
echo "$wait_insert"
mysql -h0 -P1306 -E -e "SHOW STATUS LIKE 'cluster_c4432_auto_%'" 2>&1 || true
EOF
