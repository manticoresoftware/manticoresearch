bash <<'EOF'
set -e
mysql -h0 -P1306 -e "CREATE TABLE t4432_auto (id bigint, title text);" >/tmp/c4432_auto_setup.out 2>&1
mysql -h0 -P1306 -e "ALTER CLUSTER c4432_auto ADD t4432_auto;" >>/tmp/c4432_auto_setup.out 2>&1
mysql -h0 -P1306 -e "INSERT INTO c4432_auto:t4432_auto VALUES (1,'before exit');" >>/tmp/c4432_auto_setup.out 2>&1
mysql -h0 -P2306 -e "EXIT CLUSTER c4432_auto;" >>/tmp/c4432_auto_setup.out 2>&1
echo "AUTO_SETUP_EXIT=ok"
EOF
