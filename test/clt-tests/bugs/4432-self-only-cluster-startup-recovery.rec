bash -c 'wait1=$(mysql -E -h0 -P1306 -e "debug wait c4432_preserve like '\''state'\'' option '\''timeout'\''=90;" 2>&1); wait2=$(mysql -E -h0 -P2306 -e "debug wait c4432_preserve like '\''state'\'' option '\''timeout'\''=90;" 2>&1); status1=$(mysql -E -h0 -P1306 -e "SHOW STATUS LIKE '\''cluster_c4432_preserve_%'\''" 2>&1 || true); status2=$(mysql -E -h0 -P2306 -e "SHOW STATUS LIKE '\''cluster_c4432_preserve_%'\''" 2>&1 || true); echo "$wait1" | grep -q "Value: synced" && echo "$wait2" | grep -q "Value: synced" && echo "$status1" | grep -q "Counter: cluster_c4432_preserve_nodes_set" && echo "$status1" | grep -q "127.0.0.1:1312" && echo "$status1" | grep -q "127.0.0.1:2312" && { echo "NEG_CLUSTER_SYNCED=yes"; exit 0; }; echo "NEG_CLUSTER_SYNCED=no"; cat /tmp/c4432_preserve_join.out 2>/dev/null || true; echo "$wait1"; echo "$wait2"; echo "$status1"; echo "$status2"'
‚Äì‚Äì‚Äì output ‚Äì‚Äì‚Äì
NEG_CLUSTER_SYNCED=yes
‚Äì‚Äì‚Äì input ‚Äì‚Äì‚Äì
bash <<'EOF'
seqno() { mysql -E -h0 -P"$1" -e "SHOW STATUS LIKE 'cluster_${2}_state_seqno';" 2>/tmp/c4432_preserve_seqno.err | awk '/Value:/{print $2; exit}'; }
wait_seq() { mysql -E -h0 -P"$1" -e "debug wait $2 status $3 like 'state' option 'timeout'=30;" 2>&1; }
wait_ready() { mysql -E -h0 -P"$1" -e "debug wait $2 like 'state' option 'timeout'=30;" >"/tmp/c4432_preserve_ready_$1.out" 2>&1; }
wait_ok() { echo "$1" | awk -v want="$2" '/Value:/{ if ($2>=want) ok=1 } END{ exit ok ? 0 : 1 }'; }
has_index() { mysql -N -B -h0 -P"$1" -e "SHOW STATUS LIKE 'cluster_${2}_indexes';" 2>/tmp/c4432_preserve_indexes_$1.err | grep -qw "$3"; }

mysql -h0 -P1306 -e "CREATE TABLE t4432_preserve (id bigint, title text);" >/tmp/c4432_preserve_create.out 2>&1

added=0
for attempt in 1 2 3; do
	wait_ready 2306 c4432_preserve
	before_add=$(seqno 2306 c4432_preserve)
	[ -n "$before_add" ] || before_add=0
	want_add=$((before_add+1))
	mysql -h0 -P1306 -e "ALTER CLUSTER c4432_preserve ADD t4432_preserve;" >/tmp/c4432_preserve_alter.out 2>&1
	alter_rc=$?
	after_add=$(seqno 2306 c4432_preserve)
	if [ $alter_rc -eq 0 ]; then
		wait_add=$(wait_seq 2306 c4432_preserve "$want_add")
		after_add=$(seqno 2306 c4432_preserve)
		if wait_ok "$wait_add" "$want_add" || has_index 2306 c4432_preserve t4432_preserve; then
			added=1
			break
		fi
	elif grep -q "already part of cluster" /tmp/c4432_preserve_alter.out && has_index 2306 c4432_preserve t4432_preserve; then
		added=1
		break
	fi
done

if [ "$added" = 1 ]; then
	inserted=0
	for attempt in 1 2 3; do
		wait_ready 2306 c4432_preserve
		before_insert=$(seqno 2306 c4432_preserve)
		[ -n "$before_insert" ] || before_insert=0
		want_insert=$((before_insert+1))
		mysql -h0 -P1306 -e "INSERT INTO c4432_preserve:t4432_preserve VALUES (1,'before peer stop');" >/tmp/c4432_preserve_insert_setup.out 2>&1
		insert_rc=$?
		after_insert=$(seqno 2306 c4432_preserve)
		if [ $insert_rc -eq 0 ]; then
			wait_insert=$(wait_seq 2306 c4432_preserve "$want_insert")
			after_insert=$(seqno 2306 c4432_preserve)
			if wait_ok "$wait_insert" "$want_insert"; then
				inserted=1
				break
			fi
		fi
	done
	if [ "$inserted" = 1 ]; then
		echo "NEG_TABLE_ADDED=yes"
		exit 0
	fi
fi

echo "NEG_TABLE_ADDED=no"
echo "NEG_ADD_BEFORE=$before_add NEG_ADD_WANTED=$want_add NEG_ADD_AFTER=$after_add NEG_ADD_RC=$alter_rc"
echo "NEG_INSERT_BEFORE=$before_insert NEG_INSERT_WANTED=$want_insert NEG_INSERT_AFTER=$after_insert NEG_INSERT_RC=$insert_rc"
cat /tmp/c4432_preserve_create.out /tmp/c4432_preserve_ready_*.out /tmp/c4432_preserve_alter.out /tmp/c4432_preserve_insert_setup.out 2>/dev/null || true
echo "$wait_add"
echo "$wait_insert"
mysql -h0 -P1306 -E -e "SHOW STATUS LIKE 'cluster_c4432_preserve_%'" 2>&1 || true
mysql -h0 -P2306 -E -e "SHOW STATUS LIKE 'cluster_c4432_preserve_%'" 2>&1 || true
EOF
