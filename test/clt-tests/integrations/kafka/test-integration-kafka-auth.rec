# This test validates Queue plugin resources under authentication.
#
# It covers:
# - authenticated Manticore startup with Buddy
# - Kafka source and materialized-view CRUD
# - full Kafka -> buffer -> materialized-view -> destination processing
# - source/<name> and mva/<name> grants morphing to plugin resource tables
# - read-only and writer users with different permissions
# - DROP SOURCE succeeds without direct grants on system.buffer_* because buffer-table work is internal Buddy work

––– block: ../../base/dind/init –––
––– comment –––
Set Kafka version
––– input –––
KAFKA_VERSION="4.1.0"
echo "Using Kafka version: $KAFKA_VERSION"
––– output –––
Using Kafka version: 4.1.0
––– comment –––
Create bridge network for container communication
––– input –––
docker network create app-network --driver bridge > /dev/null; echo $?
––– output –––
0
––– comment –––
Start Manticore container without searchd so auth can be configured before daemon startup
––– input –––
docker run -it --network=app-network --platform linux/amd64 --name manticore -d ghcr.io/manticoresoftware/manticoresearch:test-kit-wip_auth bash > /dev/null 2>&1; echo $?
––– output –––
0
––– comment –––
Configure auth using the same pattern as core/authentification.rec, but seed admin directly for SQL permissions tests
––– input –––
docker exec manticore bash -lc "cat > /var/lib/manticore/auth.json <<'JSON'
{\"users\":[{\"username\":\"admin\",\"salt\":\"aabbccddeeff00112233aabbccddeeff00112233\",\"hashes\":{\"password_sha1_no_salt\":\"74913f5cd5f61ec0bcfdb775414c2fb3d161b620\",\"password_sha256\":\"bc723b5179630195129574a9cf534e1fa7397f9bd166dd10b1babbe37ea52589\",\"bearer_sha256\":\"4b72aa7367f065146c7a028bc739c69c8e4bdebf7fe2d1133255c51bf36d8056\"}}],\"permissions\":[{\"username\":\"admin\",\"action\":\"read\",\"target\":\"*\",\"allow\":true},{\"username\":\"admin\",\"action\":\"write\",\"target\":\"*\",\"allow\":true},{\"username\":\"admin\",\"action\":\"schema\",\"target\":\"*\",\"allow\":true},{\"username\":\"admin\",\"action\":\"admin\",\"target\":\"*\",\"allow\":true}]}
JSON
chmod 600 /var/lib/manticore/auth.json
sed -i 's/searchd {/searchd {\nauth = 1\nauth_log_level = all/g' /etc/manticoresearch/manticore.conf
rm -f /var/log/manticore/searchd.log.auth
echo 'Auth configured'"
––– output –––
Auth configured
––– comment –––
Start authenticated searchd and wait for Buddy
––– input –––
docker exec manticore bash -lc "rm -f /var/log/manticore/searchd.log; stdbuf -oL searchd --logdebugvv > /dev/null; if timeout 10 grep -qm1 '\[BUDDY\] started' <(tail -n 1000 -f /var/log/manticore/searchd.log); then echo 'Buddy started!'; else echo 'Timeout or failed!'; tail  /var/log/manticore/searchd.log; fi"
––– output –––
Buddy started!
––– block: ../../base/start-kafka-kraft –––
––– input –––
docker exec kafka /opt/kafka/bin/kafka-topics.sh --create --topic my-data --partitions 4 --bootstrap-server localhost:9092 2>&1 | grep -o 'Created topic my-data\.' | head -n 1
––– output –––
Created topic my-data.
––– comment –––
Create Queue source, destination table, and materialized view as admin
––– input –––
docker exec manticore bash -lc "MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"CREATE SOURCE kafka_auth (id bigint, term text, abbrev '\\\$abbrev' text, GlossDef json, is_active bool) type='kafka' broker_list='kafka:9092' topic_list='my-data' consumer_group='manticore_auth' num_consumers='1' batch=50;\""; echo $?
––– output –––
0
––– input –––
docker exec manticore bash -lc "MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"CREATE TABLE destination_kafka_auth (id bigint, name text, short_name text, received_at text, size multi, is_active bool);\""; echo $?
––– output –––
0
––– input –––
docker exec manticore bash -lc "MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"CREATE MATERIALIZED VIEW view_table_auth TO destination_kafka_auth AS SELECT id, term as name, abbrev as short_name, UTC_TIMESTAMP() as received_at, GlossDef.size as size, is_active FROM kafka_auth;\""; echo $?
––– output –––
0
––– input –––
docker exec manticore bash -lc "MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -N -e \"SHOW SOURCES;\" | grep -q 'kafka_auth' && echo SOURCE_CREATED_OK"
––– output –––
SOURCE_CREATED_OK
––– input –––
docker exec manticore bash -lc "MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -N -e \"SHOW MVS;\" | grep -q 'view_table_auth' && echo MVA_CREATED_OK"
––– output –––
MVA_CREATED_OK
––– input –––
docker exec manticore bash -lc "out=\$(MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -N -e \"SHOW TABLES FROM system;\" 2>&1); echo SYSTEM_TABLES_RAW_MATCHES_BEGIN; echo \"\$out\" | grep -E 'system\\.(sources|views|buffer_kafka_auth_0)' || true; echo SYSTEM_TABLES_RAW_MATCHES_END; echo \"\$out\" | awk '{ for (i=1; i<=NF; i++) if (\$i ~ /^system\\.(sources|views|buffer_kafka_auth_0)$/) print \$i }' | sort"
––– output –––
SYSTEM_TABLES_RAW_MATCHES_BEGIN
#!/.*system\.buffer_kafka_auth_0.*/!#
#!/.*system\.sources.*/!#
#!/.*system\.views.*/!#
SYSTEM_TABLES_RAW_MATCHES_END
system.buffer_kafka_auth_0
system.sources
system.views
––– comment –––
Verify full Kafka processing
––– input –––
timeout 60 bash -c 'docker exec manticore bash -c "tail -f /var/log/manticore/searchd.log" | grep -m2 "REPLACE%20INTO%20destination_kafka_auth" > /dev/null' & GREP_PID=$!; sleep 2; docker exec kafka bash /import.sh; wait $GREP_PID && echo "Data processing completed." || echo "Data processing failed."
––– output –––
Data processing completed.
––– input –––
docker exec manticore bash -lc "MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"SELECT COUNT(*) FROM destination_kafka_auth\" | awk '/^[| ]*[0-9]+[ |]*$/ { gsub(/[^0-9]/,\"\"); print; exit }'"
––– output –––
57
––– comment –––
Create users with different permissions
––– input –––
docker exec manticore bash -lc "MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"CREATE USER 'queue_reader' IDENTIFIED BY 'queue_reader_pass'; CREATE USER 'queue_writer' IDENTIFIED BY 'queue_writer_pass';\" >/dev/null && echo USERS_CREATED_OK"
––– output –––
USERS_CREATED_OK
––– input –––
docker exec manticore bash -lc "out=\$(MYSQL_PWD=queue_reader_pass mysql -uqueue_reader -h0 -P9306 -e \"SELECT * FROM system.sources;\" 2>&1); if echo \"\$out\" | grep -q \"Permission denied for user 'queue_reader'\"; then echo SOURCE_READ_DENIED_BEFORE_GRANT_OK; else echo SOURCE_READ_DENIED_BEFORE_GRANT_FAILED; echo \"Expected permission denial while selecting system.sources before read grant. Actual output:\"; echo \"\$out\"; fi"
––– output –––
SOURCE_READ_DENIED_BEFORE_GRANT_OK
––– input –––
docker exec manticore bash -lc "out=\$(MYSQL_PWD=queue_reader_pass mysql -uqueue_reader -h0 -P9306 -e \"SELECT * FROM system.views;\" 2>&1); if echo \"\$out\" | grep -q \"Permission denied for user 'queue_reader'\"; then echo MVA_READ_DENIED_BEFORE_GRANT_OK; else echo MVA_READ_DENIED_BEFORE_GRANT_FAILED; echo \"Expected permission denial while selecting system.views before read grant. Actual output:\"; echo \"\$out\"; fi"
––– output –––
MVA_READ_DENIED_BEFORE_GRANT_OK
––– comment –––
Grant read permissions on the Queue plugin system tables and show any SQL/auth error directly.
––– input –––
docker exec manticore bash -lc "sql=\"GRANT read ON 'system.sources' TO 'queue_reader'; GRANT read ON 'system.views' TO 'queue_reader'; GRANT read ON 'system.sources' TO 'queue_writer'; GRANT read ON 'system.views' TO 'queue_writer';\"; out=\$(MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"\$sql\" 2>&1); rc=\$?; if [ \$rc -eq 0 ]; then echo READ_GRANTS_OK; else echo READ_GRANTS_FAILED rc=\$rc; echo \"Failed SQL:\"; echo \"\$sql\"; echo \"Actual output:\"; echo \"\$out\"; fi"
––– output –––
READ_GRANTS_OK
––– input –––
docker exec manticore bash -lc "out=\$(MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"SHOW PERMISSIONS;\" 2>&1); echo \"\$out\" | awk '/queue_/ { user=\"\"; action=\"\"; target=\"\"; allow=\"\"; for (i=1; i<=NF; i++) { if (\$i ~ /^queue_/) user=\$i; else if (\$i ~ /^(read|write|schema)$/) action=\$i; else if (\$i ~ /^system\\./) target=\$i; else if (\$i ~ /^[01]$/) allow=\$i } if (user && action && target && allow) print user, action, target, allow }' | sort"
––– output –––
queue_reader read system.sources 1
queue_reader read system.views 1
queue_writer read system.sources 1
queue_writer read system.views 1
––– input –––
docker exec manticore bash -lc "out=\$(MYSQL_PWD=queue_reader_pass mysql -uqueue_reader -h0 -P9306 -e \"SHOW SOURCE kafka_auth;\" 2>&1); if echo \"\$out\" | grep -q 'kafka_auth'; then echo READER_SHOW_SOURCE_OK; else echo READER_SHOW_SOURCE_FAILED; echo \"Expected SHOW SOURCE kafka_auth to return kafka_auth after read grant. Actual output:\"; echo \"\$out\"; fi"
––– output –––
READER_SHOW_SOURCE_OK
––– input –––
docker exec manticore bash -lc "out=\$(MYSQL_PWD=queue_reader_pass mysql -uqueue_reader -h0 -P9306 -e \"SHOW MV view_table_auth;\" 2>&1); if echo \"\$out\" | grep -q 'view_table_auth'; then echo READER_SHOW_MVA_OK; else echo READER_SHOW_MVA_FAILED; echo \"Expected SHOW MV view_table_auth to return view_table_auth after read grant. Actual output:\"; echo \"\$out\"; fi"
––– output –––
READER_SHOW_MVA_OK
––– input –––
docker exec manticore bash -lc "out=\$(MYSQL_PWD=queue_reader_pass mysql -uqueue_reader -h0 -P9306 -e \"ALTER MATERIALIZED VIEW view_table_auth suspended=1;\" 2>&1); rc=\$?; if echo \"\$out\" | grep -q \"Permission denied for user 'queue_reader'\"; then echo READER_WRITE_DENIED_OK; else echo READER_WRITE_DENIED_FAILED rc=\$rc; echo \"Expected queue_reader ALTER MATERIALIZED VIEW to be denied; empty output with rc=0 means it was allowed. Actual output:\"; if [ -n \"\$out\" ]; then echo \"\$out\"; else echo \"<empty>\"; fi; echo \"Post-state SHOW MV output:\"; MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"SHOW MV view_table_auth;\" 2>&1; echo \"SHOW PERMISSIONS queue_* snapshot:\"; MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"SHOW PERMISSIONS;\" 2>&1 | grep -E \"queue_(reader|writer)|user|username\" || true; echo \"auth log file status after unexpected ALTER allowance:\"; ls -l /var/log/manticore/searchd.log.auth 2>&1 || true; echo \"auth log after unexpected ALTER allowance:\"; tail  /var/log/manticore/searchd.log.auth 2>&1 || true; echo \"focused searchd.log lines after unexpected ALTER allowance:\"; grep -E \"ExecuteSqlQuery|User:|Permission denied|denied|ALTER MATERIALIZED|DROP SOURCE|DROP MV|SHOW PERMISSIONS|queue_reader|queue_writer|BUDDY\" /var/log/manticore/searchd.log 2>&1 || true; echo \"searchd.log tail after unexpected ALTER allowance:\"; tail -n 80 /var/log/manticore/searchd.log || true; fi"
––– output –––
READER_WRITE_DENIED_OK
––– input –––
docker exec manticore bash -lc "out=\$(MYSQL_PWD=queue_reader_pass mysql -uqueue_reader -h0 -P9306 -e \"DROP SOURCE kafka_auth;\" 2>&1); rc=\$?; if echo \"\$out\" | grep -q \"Permission denied for user 'queue_reader'\"; then echo READER_DROP_SOURCE_DENIED_OK; else echo READER_DROP_SOURCE_DENIED_FAILED rc=\$rc; echo \"Expected queue_reader DROP SOURCE to be denied; empty output with rc=0 means it was allowed. Actual output:\"; if [ -n \"\$out\" ]; then echo \"\$out\"; else echo \"<empty>\"; fi; echo \"Post-state SHOW SOURCES/MVS output:\"; MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"SHOW SOURCES; SHOW MVS;\" 2>&1; echo \"SHOW TABLES FROM system snapshot:\"; MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"SHOW TABLES FROM system;\" 2>&1 | grep -E \"system\\.(sources|views|buffer_kafka_auth_0)|Tables\" || true; echo \"SHOW PERMISSIONS queue_* snapshot:\"; MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"SHOW PERMISSIONS;\" 2>&1 | grep -E \"queue_(reader|writer)|user|username\" || true; echo \"auth log file status after unexpected DROP SOURCE allowance:\"; ls -l /var/log/manticore/searchd.log.auth 2>&1 || true; echo \"auth log after unexpected DROP SOURCE allowance:\"; tail  /var/log/manticore/searchd.log.auth 2>&1 || true; echo \"focused searchd.log lines after unexpected DROP SOURCE allowance:\"; grep -E \"ExecuteSqlQuery|User:|Permission denied|denied|ALTER MATERIALIZED|DROP SOURCE|DROP MV|SHOW PERMISSIONS|queue_reader|queue_writer|BUDDY\" /var/log/manticore/searchd.log 2>&1 || true; echo \"searchd.log tail after unexpected DROP SOURCE allowance:\"; tail -n 80 /var/log/manticore/searchd.log || true; fi"
––– output –––
READER_DROP_SOURCE_DENIED_OK
––– input –––
docker exec manticore bash -lc "out=\$(MYSQL_PWD=queue_reader_pass mysql -uqueue_reader -h0 -P9306 -e \"DROP MV view_table_auth;\" 2>&1); rc=\$?; if echo \"\$out\" | grep -q \"Permission denied for user 'queue_reader'\"; then echo READER_DROP_MVA_DENIED_OK; else echo READER_DROP_MVA_DENIED_FAILED rc=\$rc; echo \"Expected queue_reader DROP MV to be denied; empty output with rc=0 means it was allowed. Actual output:\"; if [ -n \"\$out\" ]; then echo \"\$out\"; else echo \"<empty>\"; fi; echo \"Post-state SHOW SOURCES/MVS output:\"; MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"SHOW SOURCES; SHOW MVS;\" 2>&1; echo \"SHOW TABLES FROM system snapshot:\"; MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"SHOW TABLES FROM system;\" 2>&1 | grep -E \"system\\.(sources|views|buffer_kafka_auth_0)|Tables\" || true; echo \"SHOW PERMISSIONS queue_* snapshot:\"; MYSQL_PWD=adminpass mysql -uadmin -h0 -P9306 -e \"SHOW PERMISSIONS;\" 2>&1 | grep -E \"queue_(reader|writer)|user|username\" || true; echo \"auth log file status after unexpected DROP MV allowance:\"; ls -l /var/log/manticore/searchd.log.auth 2>&1 || true; echo \"auth log after unexpected DROP MV allowance:\"; tail  /var/log/manticore/searchd.log.auth 2>&1 || true; echo \"focused searchd.log lines after unexpected DROP MV allowance:\"; grep -E \"ExecuteSqlQuery|User:|Permission denied|denied|ALTER MATERIALIZED|DROP SOURCE|DROP MV|SHOW PERMISSIONS|queue_reader|queue_writer|BUDDY\" /var/log/manticore/searchd.log 2>&1 || true; echo \"searchd.log tail after unexpected DROP MV allowance:\"; tail -n 80 /var/log/manticore/searchd.log || true; fi"
––– output –––
READER_DROP_MVA_DENIED_OK
