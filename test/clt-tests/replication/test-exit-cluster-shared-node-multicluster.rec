––– input –––
bash -c 'end=$((SECONDS+120)); while [ $SECONDS -lt $end ]; do view=$(mysql -h0 -P1306 -e "SHOW STATUS LIKE '\''cluster_${CLUSTER_A_NAME}_nodes_view'\''\\G" 2>/dev/null || true); setv=$(mysql -h0 -P1306 -e "SHOW STATUS LIKE '\''cluster_${CLUSTER_A_NAME}_nodes_set'\''\\G" 2>/dev/null || true); echo "$view" | grep -q "Counter: cluster_${CLUSTER_A_NAME}_nodes_view" || { sleep 1; continue; }; echo "$setv" | grep -q "Counter: cluster_${CLUSTER_A_NAME}_nodes_set" || { sleep 1; continue; }; echo "$view" | grep -q "2306" && { sleep 1; continue; }; echo "$setv" | grep -q "2306" && { sleep 1; continue; }; echo "Cluster A survivor converged"; echo "$view" | grep "Value:"; echo "$setv" | grep "Value:"; exit 0; done; echo "Timeout waiting for cluster A survivor cleanup"; exit 1'
