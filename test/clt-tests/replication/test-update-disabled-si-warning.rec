––– input –––
export CLUSTER_NAME=gh4460
––– output –––
––– input –––
cluster_state() { mysql -h0 -P$1 -e "SHOW STATUS LIKE 'cluster_${CLUSTER_NAME}_node_state'" 2>/dev/null | grep "cluster_${CLUSTER_NAME}_node_state" | tr -s ' ' | cut -d' ' -f4; }; wait_synced() { port=$1; for i in `seq 1 60`; do [ "$(cluster_state $port)" = synced ] && return 0; sleep 0.5; done; return 1; }; index_enabled() { mysql -h0 -P$1 -e "SHOW TABLE products_gh4460 INDEXES" | grep '| *active ' | tr -s ' ' | cut -d' ' -f6; }; fail_markers() { for inst in 1 2 3; do grep -E 'Failed to apply trx|Node consistency compromised|FATAL|committed 0|abort from replication provider' /var/log/manticore-${inst}/searchd.log || true; done; }
––– output –––
––– block: ../base/replication/create-cluster –––
––– input –––
export INSTANCE=3
––– output –––
––– block: ../base/replication/join-cluster-on-all-nodes –––
––– input –––
for port in 1306 2306 3306; do wait_synced ${port} && echo "port ${port} synced" || { echo "port ${port} not synced"; false; }; done
