––– comment –––
Regression: FAIL_006 / FAIL_015 — DROP TABLE without cluster prefix on a
clustered sharded table must reject with a clear hint pointing to the
correct cluster-prefixed form. Old behaviour was a silent no-op success
or "unknown table" depending on path.

––– input –––
export INSTANCE=1
––– output –––
––– block: ../../base/replication/start-searchd-precach –––
––– input –––
export INSTANCE=2
––– output –––
––– block: ../../base/replication/start-searchd-precach –––
––– input –––
export CLUSTER_NAME=c
––– output –––
––– block: ../../base/replication/create-cluster –––
––– block: ../../base/replication/join-cluster-on-all-nodes –––
––– input –––
mysql -h0 -P1306 -e "create table ${CLUSTER_NAME}:t6(id bigint, body text) shards='2' rf='2';"; echo $?
––– output –––
0
––– input –––
mysql -h0 -P1306 -e "drop table t6;"
––– output –––
ERROR 1064 (42000) at line 1: table 't6' belongs to cluster 'c': use DROP TABLE c:t6
––– input –––
mysql -h0 -P1306 -e "show tables like 't6';"
––– output –––
+-------+-------+
| Table | Type  |
+-------+-------+
| t6    | shard |
+-------+-------+
