Regression: FAIL_026 — FLUSH RAMCHUNK on a public sharded table (type='shard')
must fan out to physical shards instead of failing with
"FLUSH RAMCHUNK requires an existing RT table".

––– input –––
export INSTANCE=1
––– output –––
––– block: ../../base/replication/start-searchd-precach –––
––– input –––
mysql -h0 -P1306 -e "create table t26(id bigint, title text) shards='2' rf='1';"; echo $?
––– output –––
0
––– input –––
mysql -h0 -P1306 -e "insert into t26(id,title) values(1,'a'),(2,'b'),(3,'c');"; echo $?
––– output –––
0
––– input –––
mysql -h0 -P1306 -e "flush ramchunk t26;"; echo $?
––– output –––
0
