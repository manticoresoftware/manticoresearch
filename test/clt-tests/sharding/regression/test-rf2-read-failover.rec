––– comment –––
Regression: FAIL_010-D — on an RF=2 sharded table, the first SELECT after
one replica goes down used to return partial data (mirror agent picked the
dead replica, daemon didn't retry within the same query). Buddy now emits
agent strings with [retry_count=2,ha_strategy=noerrors] so the daemon
fails over to the live mirror immediately. First SELECT after kill
returns the full count.

––– input –––
export INSTANCE=1
––– output –––
––– block: ../../base/replication/start-searchd-precach –––
––– input –––
export INSTANCE=2
––– output –––
––– block: ../../base/replication/start-searchd-precach –––
––– input –––
export CLUSTER_NAME=c
––– output –––
––– block: ../../base/replication/create-cluster –––
––– block: ../../base/replication/join-cluster-on-all-nodes –––
––– input –––
mysql -h0 -P1306 -e "create table c:rm(id bigint, body text) shards='2' rf='2';"; echo $?
––– output –––
0
––– input –––
mysql -h0 -P1306 -e "insert into rm(id,body) values(1,'a'),(2,'b'),(3,'c'),(4,'d');"; echo $?
––– output –––
0
––– input –––
mysql -h0 -P1306 -e "select count(*) c from rm where id>0;"
––– output –––
+------+
| c    |
+------+
|    4 |
+------+
––– input –––
mysql -h0 -P1306 -e "show create table rm option force=1\G" | grep -o "retry_count=2,ha_strategy=noerrors" | head -1
––– output –––
retry_count=2,ha_strategy=noerrors
––– input –––
kill -9 $(cat /var/log/manticore-2/searchd.pid); sleep 1
––– output –––
––– input –––
mysql -h0 -P1306 -e "select count(*) c from rm where id>0;"
––– output –––
+------+
| c    |
+------+
|    4 |
+------+
––– input –––
mysql -h0 -P1306 -e "select count(*) c from rm where id>0;"
––– output –––
+------+
| c    |
+------+
|    4 |
+------+
