––– comment –––
Regression: FAIL_009 (daemon) — mixing INSERT and REPLACE inside a single
transaction on a sharded table used to be rejected with "current txn can
not mix INSERT and REPLACE". The per-row m_bReplace flag handles each row
independently, so the mix is now allowed (matches plain RT semantics).

––– input –––
export INSTANCE=1
––– output –––
––– block: ../../base/replication/start-searchd-precach –––
––– input –––
mysql -h0 -P1306 -e "create table t9(id bigint, title text, group_id int) shards='2' rf='1';"; echo $?
––– output –––
0
––– input –––
mysql -h0 -P1306 <<'SQL'
BEGIN;
INSERT INTO t9(id,title,group_id) VALUES(1,'one',10);
REPLACE INTO t9(id,title,group_id) VALUES(1,'one replaced',11);
COMMIT;
SQL
echo $?
––– output –––
0
––– input –––
mysql -h0 -P1306 -e "select count(*) as c from t9 where id>0;"
––– output –––
+------+
| c    |
+------+
|    1 |
+------+
