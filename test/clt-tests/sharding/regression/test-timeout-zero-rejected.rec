––– comment –––
Regression: FAIL_039 — timeout='0' used to surface 'Waiting timeout exceeded'
to the user while the sharded create silently completed in the background,
leaving an active table behind a reported failure. Buddy now rejects
timeout<1 up-front so no orphan table is created.

––– input –––
export INSTANCE=1
––– output –––
––– block: ../../base/replication/start-searchd-precach –––
––– input –––
mysql -h0 -P1306 -e "create table t39(id bigint, title text) shards='2' rf='1' timeout='0';"
––– output –––
ERROR 1064 (42000) at line 1: You cannot set timeout less than 1 second
––– input –––
mysql -h0 -P1306 -e "show tables like 't39';"
––– output –––
––– input –––
mysql -h0 -P1306 -e "create table t39_ok(id bigint, title text) shards='2' rf='1' timeout='5';"; echo $?
––– output –––
0
––– input –––
mysql -h0 -P1306 -e "show tables like 't39_ok';"
––– output –––
+--------+-------+
| Table  | Type  |
+--------+-------+
| t39_ok | shard |
+--------+-------+
