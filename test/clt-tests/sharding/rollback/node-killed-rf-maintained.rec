––– comment –––
Start nodes 1, 2
––– input –––
export INSTANCE=1
––– output –––
––– block: ../../base/replication/start-searchd-precach –––
––– input –––
export INSTANCE=2
––– output –––
––– block: ../../base/replication/start-searchd-precach –––
––– comment –––
Create table with RF=2 - auto-sharding creates cluster c
––– input –––
mysql -h0 -P1306 -e "CREATE TABLE c:data (id bigint, value string) shards='2' rf='2'"; echo $?
––– output –––
0
––– comment –––
Insert test data (table name WITHOUT cluster prefix)
––– input –––
mysql -h0 -P1306 -e "INSERT INTO data (id, value) VALUES (1, 'test1'), (2, 'test2')"; echo $?
––– output –––
0
––– comment –––
Kill node 2
––– input –––
export INSTANCE=2; stdbuf -oL searchd --stopwait -c test/clt-tests/base/searchd-with-flexible-ports.conf > /dev/null; echo "Node 2 killed"
––– output –––
Node 2 killed
––– comment –––
Verify cluster still primary on node 1 (RF maintained)
––– input –––
sleep 10; mysql -h0 -P1306 -e "SHOW STATUS LIKE 'cluster_c_status'\G"
––– output –––
*************************** 1. row ***************************
Counter: cluster_c_status
  Value: primary
––– comment –––
Insert more data while node 2 is down
––– input –––
mysql -h0 -P1306 -e "INSERT INTO data (id, value) VALUES (3, 'test3')"; echo $?
––– output –––
0
––– comment –––
Restart node 2
––– input –––
export INSTANCE=2
––– output –––
––– block: ../../base/replication/start-searchd-precach –––
––– comment –––
Wait for node 2 to rejoin
––– input –––
sleep 20
––– output –––
––– comment –––
Verify both nodes synced and RF maintained
––– input –––
mysql -h0 -P1306 -e "SHOW STATUS LIKE 'cluster_c_status'\G"
––– output –––
*************************** 1. row ***************************
Counter: cluster_c_status
  Value: primary
––– input –––
mysql -h0 -P2306 -e "SHOW STATUS LIKE 'cluster_c_status'\G"
––– output –––
*************************** 1. row ***************************
Counter: cluster_c_status
  Value: primary
––– comment –––
Verify all 3 records visible on both nodes after rejoin (RF=2 replication)
––– input –––
mysql -h0 -P1306 -sN -e "SELECT COUNT(*) FROM data"
––– output –––
3
––– input –––
mysql -h0 -P2306 -sN -e "SELECT COUNT(*) FROM data"
––– output –––
3
––– comment –––
Cleanup
––– input –––
mysql -h0 -P1306 -e "DROP TABLE IF EXISTS data"; echo $?
––– output –––
0
