{"update":{"index":"shard_http_bulk_local","id":11,"doc":{"gid":111}}}
'\'' | tr -d '\''\n'\''); items=$(printf "%s" "$out" | grep -o "\"bulk\"" | wc -l | tr -d " "); echo "$out" | grep -F "\"created\":1" >/dev/null || { echo "$out"; exit 1; }; echo "$out" | grep -F "\"updated\":1" >/dev/null || { echo "$out"; exit 1; }; echo "$out" | grep -F "\"errors\":false" >/dev/null || { echo "$out"; exit 1; }; echo "items=$items created=1 updated=1 errors=false";'
