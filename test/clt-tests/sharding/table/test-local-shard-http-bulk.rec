{"insert":{"index":"shard_http_bulk_local","id":1,"doc":{"title":"bulk-insert-1","gid":10}}}
{"create":{"index":"shard_http_bulk_local","id":2,"doc":{"title":"bulk-create-2","gid":20}}}
') ; printf '%s\n' "$BULK_INSERT_CREATE" | tr -d '\n' | sed -n 's/.*"created":\([0-9][0-9]*\).*"deleted":\([0-9][0-9]*\).*"updated":\([0-9][0-9]*\).*"errors":\([^,}]*\).*/created=\1 deleted=\2 updated=\3 errors=\4/p'
