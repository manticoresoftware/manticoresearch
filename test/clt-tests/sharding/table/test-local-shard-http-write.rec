––– input –––
BULK_INSERT=$(curl -s -X POST http://localhost:1308/bulk -H "Content-Type: application/x-ndjson" -d '
{"insert":{"index":"shard_http_local","id":3,"doc":{"title":"bulk-insert-3","gid":30}}}
{"insert":{"index":"shard_http_local","id":4,"doc":{"title":"bulk-insert-4","gid":40}}}
') ; printf '%s\n' "$BULK_INSERT" | tr -d '\n' | sed -n 's/.*"created":\([0-9][0-9]*\).*"errors":\([^,}]*\).*/created=\1 errors=\2/p'
––– output –––
created=2 errors=false
