curl -s -X POST http://localhost:1308/replace -d '{"table":"shard_http_local","id":1,"doc":{"title":"http-replace-1","gid":11}}' | tr -d '\n' | sed -n 's/.*"result":"\([^"]*\)".*/\1/p'
