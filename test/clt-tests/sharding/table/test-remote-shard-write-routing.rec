––– input –––
mysql -h0 -P1306 -e "SELECT id, title, gid FROM shard_remote_ok ORDER BY id ASC;" | awk -F'|' 'BEGIN{OFS="\t"} /^[|]/{for(i=2;i<=4;i++) gsub(/^ +| +$/,"",$i); if ($2!="" && $2!="id") print $2,$3,$4} /^[0-9]+\t/{print $0}'
