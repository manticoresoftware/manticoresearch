mysql -h0 -P1306 -e "BEGIN; INSERT INTO shard_remote_ok (id, title, gid) VALUES (6, 'local-6', 60), (7, 'remote-7', 70); COMMIT; REPLACE INTO shard_remote_ok (id, title, gid) VALUES (3, 'r3-upd', 300);"
