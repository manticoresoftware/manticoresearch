	<!-- ================================== Handling ALTER DROP COLUMN -->
	drop table if exists t;
	CREATE TABLE t (f text, s string, v float_vector knn_type='hnsw' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2' from='f,s');
	alter table t drop column s;
	alter table t drop column f;
	insert into t(id,f,s) values(1,'f','s');
	alter table t drop column s;
	alter table t drop column f;
	flush ramchunk t;
	alter table t drop column s;
	alter table t drop column f;
	ALTER TABLE t ADD COLUMN v2 float_vector knn_type='hnsw' from='f,s' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2';
	insert into t(id,f,s) values(2,'f2','s2');
	alter table t drop column s;
	alter table t drop column f;
	flush ramchunk t;
	alter table t drop column s;
	alter table t drop column f;
	alter table t drop column v2;
	alter table t drop column s;
	alter table t drop column f;
	alter table t drop column v;
	alter table t drop column s;
	alter table t drop column f;
	ALTER TABLE t ADD COLUMN v float_vector knn_type='hnsw' from='f' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2';
