	select * from t order by id asc;
	ALTER TABLE t ADD COLUMN f text;
	INSERT INTO t(id) VALUES (3);
	ALTER TABLE t ADD COLUMN v2 float_vector knn_type='hnsw' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2' from='f';
	INSERT INTO t(id,v,v2) VALUES (4, (),());
	INSERT INTO t(id,v,v2) VALUES (5, NULL,());
	INSERT INTO t(id,v,v2) VALUES (6, (), NULL);
	INSERT INTO t(id,v,v2) VALUES (7, NULL, NULL);
