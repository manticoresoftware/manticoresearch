	CREATE TABLE t (f text, m multi, v float_vector knn_type='hnsw' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2' from='f');
	INSERT INTO t (id,f,m) VALUES (1,'a',(1));
	INSERT INTO t (id,v,m) VALUES(2,(),(7,7,3,4,5,5,6,6));
	SELECT id,f,m,length(v),item(v,0),knn_dist() FROM t where knn(v,'a');
	INSERT INTO t (id,f,m) VALUES (3,'b',(1,2,3)),(4,'c',(999,998,997));
	SELECT id,f,m,length(v),item(v,0),knn_dist() FROM t where knn(v,'b');
	SELECT id,f,m,length(v),item(v,0) FROM t;
	ALTER TABLE t ADD COLUMN m2 multi64;
	INSERT INTO t (id,m2) VALUES (5,(999,998,997));
	SELECT id,f,m,m2,length(v),item(v,0) FROM t;
	ALTER TABLE t ADD COLUMN v2 float_vector knn_type='hnsw' from='f' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2';
	SELECT id,f,m,m2,length(v),item(v,0),length(v2),item(v2,0) FROM t;
	INSERT INTO t (id,f) VALUES (6,'abc');
	ALTER TABLE t REBUILD EMBEDDINGS;
	SELECT id,f,m,m2,length(v),item(v,0),length(v2),item(v2,0) FROM t;

	<!-- ================================== automerge vs alter race -->
	drop table if exists t;
	create table t (f text, v float_vector knn_type='hnsw' from='f' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2',
		v15 float_vector knn_type='hnsw' from='f' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2',
		v2 float_vector knn_type='hnsw' from='f' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2',
		v3 float_vector knn_type='hnsw' from='f' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2') optimize_cutoff='1';
	insert into t(id,f) values(1,'f_1'),(2,'f_2');
	alter table t rebuild embeddings;
	flush ramchunk t;
	insert into t(id,f,v,v2) values(3,'f_3', (), ());
	replace into t(id,f,v,v2,v3) values(1,'f_1',(),(),());
	flush ramchunk t;
	replace into t(id,f,v,v2,v3) values(3,'f_3', (),(),());
	alter table t rebuild embeddings;
	replace into t(id,f) values(1,'f_1'),(2,'f_2'),(3,'f_3');
	alter table t add column v4 float_vector knn_type='hnsw' from='' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2';

	<!-- ================================== ALTER EMBEDDINGS unknown table -->
	ALTER TABLE unknown REBUILD EMBEDDINGS;

	<!-- ================================== columnar vector + alter row-wise vector + alter rebuild -->
	drop table if exists t;
	create table t (f text, v float_vector knn_type='hnsw' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2' from='f' engine='columnar');
	insert into t(id,f) values(1,'f1');
	alter table t add column v2 float_vector knn_type='hnsw' from='f' MODEL_NAME='sentence-transformers/all-MiniLM-L6-v2' hnsw_similarity='l2';
	desc t;
	insert into t(id,f) values(2,'f2');
	select id,f,length(v),item(v,0),length(v2),item(v2,0),knn_dist() from t where knn(v2, 'f1');
	alter table t rebuild embeddings;
	show warnings;
	select id,f,length(v),item(v,0),length(v2),item(v2,0),knn_dist() from t where knn(v2, 'f1');

