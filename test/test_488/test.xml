<?xml version="1.0" encoding="utf-8"?>
<test>
<name>replication duplicates bulk on IST replay</name>

<requires>
	<replication/>
	<http/>
	<non-windows/>
	<force-rt/>
	<heavy/>
</requires>
<skip_indexer/>
<num_agents>3</num_agents>

<config>

<agent0>
searchd
{
	<searchd_settings/>
	data_dir = <data_path path="data0"/>
	server_id = <agent_id/>
}
</agent0>
<agent1>
searchd
{
	<searchd_settings/>
	data_dir = <data_path path="data1"/>
	server_id = <agent_id/>
}
</agent1>
<agent2>
searchd
{
	<searchd_settings/>
	data_dir = <data_path path="data2"/>
	server_id = <agent_id/>
}
</agent2>

</config>

<queries>

<!-- create cluster and table on node0 -->
<sphinxql d="0">
	drop table if exists j;
	create table j (
		f text,
		vec float_vector
	);
	create cluster e;
	alter cluster e add j;
</sphinxql>

<!-- join node1 and node2 -->
<sphinxql d="1" cluster_connect="0">
	join cluster e at '%addr_connect%';
</sphinxql>

<sphinxql d="2" cluster_connect="0">
	join cluster e at '%addr_connect%';
</sphinxql>

<sphinxql d="0" system="wait-ready" cluster="e"/>
<sphinxql d="1" system="wait-ready" cluster="e"/>
<sphinxql d="2" system="wait-ready" cluster="e"/>

<sphinxql d="0">show status like 'cluster_e_status';</sphinxql>
<sphinxql d="1">show status like 'cluster_e_status';</sphinxql>
<sphinxql d="2">show status like 'cluster_e_status';</sphinxql>

<!-- stop node1 so it will catch up through IST later -->
<sphinxql d="1" system="stop-agent"/>

<sphinxql d="0">show status like 'cluster_e_status';</sphinxql>
<sphinxql d="2">show status like 'cluster_e_status';</sphinxql>

<!-- populate node0 through raw HTTP /bulk with duplicate ids inside each request -->
