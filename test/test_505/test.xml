<?xml version="1.0" encoding="utf-8"?>
<test>

<name>utf-8 safe truncation for long SQL parse errors</name>

<requires>
	<force-rt/>
	<http/>
</requires>

<skip_indexer/>

<config>
searchd
{
	<searchd_settings/>
	data_dir = <data_path path="data0"/>
	binlog_path =
}
</config>

<queries>
<sphinxql>
	drop table if exists issue4615;
	create table issue4615(version int, meta_content text);
	set session character_set_results = 'utf8mb4';
	REPLACE INTO issue4615 SET version = 25, meta_content = '————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————', WHERE id = 1000;
	select count(*) from issue4615;
</sphinxql>
</queries>

<httpqueries>
<query endpoint="sql?mode=raw" method="post">REPLACE INTO issue4615 SET version = 25, meta_content = '————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————————', WHERE id = 1000</query>
<query endpoint="sql?mode=raw" method="post">DROP TABLE issue4615</query>
</httpqueries>

</test>
